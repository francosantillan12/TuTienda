<h1>{{tituloPagina}}</h1>

<div class="tabs" id="tabs">
  <div class="tab-links">
    <a href="#productos" data-tab="productos" class="active">Productos</a>
    <a href="#realtime" data-tab="realtime">Administración</a>
  </div>

  <div class="tab-content" id="contenido-tabs">
    
    <!-- Panel Productos -->
    <div data-panel="productos">
    <h2>Bienvenido a TuTienda</h2>

<p>
  TuTienda es una plataforma para gestionar productos, ventas y clientes
  desde una sola aplicación.
</p>

<p>
  Navegá por el catálogo de productos, administrá tu negocio y realizá
  compras de forma simple y segura.
</p>
    </div>

    <!-- Panel Tiempo Real -->
    <div data-panel="realtime" class="oculto">
      <p>Para ver los productos en vivo y formularios de crear/eliminar, entrá acá:</p>
      <p><a href="/realtimeproducts">/realtimeproducts</a></p>
    </div>

  </div>
</div>

<script>
  (function(){
    var cont = document.getElementById("contenido-tabs");
    var links = document.querySelectorAll('.tab-links a');

    function activar(tab){
      links.forEach(function(a){
        a.classList.toggle('active', a.dataset.tab === tab);
      });

      var panels = cont.querySelectorAll('[data-panel]');
      panels.forEach(function(p){
        p.classList.toggle('oculto', p.getAttribute('data-panel') !== tab);
      });
    }

    links.forEach(function(a){
      a.addEventListener('click', function(e){
        e.preventDefault();
        activar(a.dataset.tab);
        history.replaceState(null, '', '#' + a.dataset.tab);
      });
    });

    var hash = location.hash.replace('#','');
    if (hash === 'realtime' || hash === 'productos') activar(hash);
  })();
</script>
