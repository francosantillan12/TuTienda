<div id="caja" data-carrito="{{carrito._id}}">

    <h1>💵 Caja</h1>

    <div class="caja-total">

        <span>Total a cobrar</span>

        <h2>$ {{total}}</h2>

    </div>

    <div class="acciones-caja">

        <button id="btn-vaciar" class="btn-vaciar">
            🗑 Cancelar venta
        </button>

        <button id="btn-comprar" class="btn-comprar">
            💳 Cobrar
        </button>

    </div>

    {{#if carrito.products.length}}

    <table class="tabla-caja">

        <thead>

            <tr>

                <th>Producto</th>
                <th>Cantidad</th>
                <th>Precio Unit.</th>
                <th>Subtotal</th>
                <th></th>

            </tr>

        </thead>

        <tbody>

            {{#each carrito.products}}

            {{#if this.product}}

            <tr>

                <td>
                    {{this.product.titulo}}
                </td>

                <td>

                    <button class="btn-restar" data-pid="{{this.product._id}}" data-quantity="{{this.quantity}}">

                        ➖

                    </button>

                    <span class="cantidad-producto">

                        {{this.quantity}}

                    </span>

                    <button class="btn-sumar" data-pid="{{this.product._id}}" data-quantity="{{this.quantity}}">

                        ➕

                    </button>

                </td>

                <td>
                    ${{this.product.precio}}
                </td>

                <td>
                    ${{multiplicar this.product.precio this.quantity}}
                </td>

                <td>

                    <button class="btn-eliminar" data-pid="{{this.product._id}}">

                        ❌

                    </button>

                </td>

            </tr>

            {{/if}}

            {{/each}}

        </tbody>

    </table>

    {{else}}

    <p class="caja-vacia">
        No hay productos cargados en la caja.
    </p>

    {{/if}}

</div>

<script defer src="/public/js/caja.js"></script>